# Porta em que a API vai rodar
PORT=4000

# URL do Realtime Database (Firebase Console > Realtime Database)
FIREBASE_DATABASE_URL=https://elevate-tech-company-default-rtdb.firebaseio.com

# Caminho do arquivo da service account (gerado no Firebase Console)
# Project Settings > Service accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Segredo usado para assinar os tokens de sessão (JWT).
# Gere um valor forte, por exemplo: openssl rand -hex 64
JWT_SECRET=troque-este-valor-por-uma-string-aleatoria-e-longa

# Duração do token quando "lembrar de mim" NÃO está marcado
JWT_EXPIRES_IN_SHORT=1d
# Duração do token quando "lembrar de mim" está marcado
JWT_EXPIRES_IN_LONG=30d

# Origem permitida para chamadas à API (o endereço do seu front-end)
CLIENT_ORIGIN=http://127.0.0.1:5500

# true em produção (HTTPS) — o cookie de sessão só é enviado em conexões seguras
COOKIE_SECURE=false
